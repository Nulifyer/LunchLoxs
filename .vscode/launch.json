{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "env": {
        "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/todos?sslmode=disable",
        "PORT": "8000",
        "FRONTEND_URL": "http://localhost:5000",
        "BIND_HOST": "127.0.0.1"
      }
    },
    {
      "name": "Debug Frontend (Brave)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5000",
      "webRoot": "${workspaceFolder}/frontend",
      "runtimeExecutable": "C:/Program Files/BraveSoftware/Brave-Browser/Application/brave.exe",
      "runtimeArgs": ["--incognito"]
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Debug Backend", "Debug Frontend (Brave)"],
      "preLaunchTask": "dev-frontend",
      "postDebugTask": "teardown",
      "stopAll": true
    }
  ]
}
