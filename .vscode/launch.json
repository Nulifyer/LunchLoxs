{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug-backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "env": {
        "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/todos?sslmode=disable",
        "PORT": "8000",
        "FRONTEND_URL": "http://localhost:5000",
        "BIND_HOST": "127.0.0.1"
      }
    },
    {
      "name": "debug-frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5000",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "run-frontend"
    }
  ]
}
