{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "infra",
      "type": "shell",
      "command": "podman compose up -d postgres migrate pgadmin llama browserless",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "llm-extraction-test",
      "type": "shell",
      "command": "bun run dev-data/llm-test/run-llm-extraction-test.ts",
      "dependsOn": "infra",
      "options": {
        "env": {
          "LLM_ENDPOINT": "http://localhost:8081",
          "LLM_PROMPT_DIR": "${workspaceFolder}/prompts/url-import",
          "BROWSERLESS_ENDPOINT": "http://localhost:3000",
          "BROWSERLESS_TOKEN": "dev-token"
        }
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "frontend-dev",
      "type": "shell",
      "command": "cd frontend && bun run build && bun run dev",
      "dependsOn": "infra",
      "options": { "env": { "LOG_LEVEL": "debug" } },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Dev server running at"
        }
      },
      "group": "build"
    },
    {
      "label": "frontend-watch",
      "type": "shell",
      "command": "cd frontend && bun run watch",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "waiting for changes"
        }
      },
      "group": "build"
    },
    {
      "label": "dev-frontend",
      "dependsOn": ["frontend-dev", "frontend-watch"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "teardown",
      "type": "shell",
      "command": "$ErrorActionPreference = 'SilentlyContinue'; Get-Process server,testserver,bun | Stop-Process -Force; podman compose down -v",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
