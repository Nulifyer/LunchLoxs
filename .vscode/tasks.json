{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "infra",
      "type": "shell",
      "command": "podman compose up -d postgres migrate pgadmin llama browserless",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "frontend-dev",
      "type": "shell",
      "command": "cd frontend && bun run build && bun run dev",
      "dependsOn": "infra",
      "options": { "env": { "LOG_LEVEL": "debug" } },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Dev server running at"
        }
      },
      "group": "build"
    },
    {
      "label": "frontend-watch",
      "type": "shell",
      "command": "cd frontend && bun run watch",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "waiting for changes"
        }
      },
      "group": "build"
    },
    {
      "label": "dev-frontend",
      "dependsOn": ["frontend-dev", "frontend-watch"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "teardown",
      "type": "shell",
      "command": "taskkill //F //IM server.exe 2>nul; taskkill //F //IM testserver.exe 2>nul; pkill -f 'bun run dev|bun run watch' 2>/dev/null; podman compose down -v",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
