# LunchLoxs production environment
# Copy this file to .env and fill in your values

# Frontend
FRONTEND_HOST=lunchloxs.example.com
FRONTEND_HTTPS=true

# Backend (optional — only set for cross-origin deployments)
# Leave commented for same-origin, where Traefik routes /api and /ws
# to the backend on the same host as the frontend.
# BACKEND_HOST=api.lunchloxs.example.com
# BACKEND_HTTPS=true

# PostgreSQL
POSTGRES_USER=lunchloxs
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=lunchloxs

# Optional: AI-assisted recipe URL import
# Point this at any OpenAI-style chat completions service. The backend does not
# send a model name by default, so model selection stays owned by that service.
# LLM_ENDPOINT=http://ryzen-ai-llm:8080
# LLM_API_KEY=
# LLM_PROMPT_DIR=/app/prompts/url-import
# LLM_TIMEOUT=20m
# LLM_DEFAULT_TEMPERATURE=0.7
# LLM_DEFAULT_TOP_P=0.8
# LLM_DEFAULT_MAX_TOKENS=8192
# LLM_PASS0_TEMPERATURE=0.6
# LLM_PASS0_TOP_P=0.95
# LLM_PASS0_MAX_TOKENS=16384
# LLM_PASS1_TEMPERATURE=0.6
# LLM_PASS1_TOP_P=0.95
# LLM_PASS1_MAX_TOKENS=16384
# LLM_PASS2_TEMPERATURE=0.7
# LLM_PASS2_TOP_P=0.8
# LLM_PASS2_MAX_TOKENS=8192
# LLM_PASS3_TEMPERATURE=0.6
# LLM_PASS3_TOP_P=0.95
# LLM_PASS3_MAX_TOKENS=16384
#
# Optional: Browserless endpoint for JS-rendered pages during URL import
# BROWSERLESS_ENDPOINT=http://browserless:3000
# BROWSERLESS_TOKEN=
