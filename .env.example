# LunchLoxs production environment
# Copy this file to .env and fill in your values

# Frontend
FRONTEND_HOST=lunchloxs.example.com
FRONTEND_HTTPS=true

# Backend (optional — only set for cross-origin deployments)
# Leave commented for same-origin, where Traefik routes /api and /ws
# to the backend on the same host as the frontend.
# BACKEND_HOST=api.lunchloxs.example.com
# BACKEND_HTTPS=true

# PostgreSQL
POSTGRES_USER=lunchloxs
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=lunchloxs
