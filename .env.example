# LunchLoxs production environment
# Copy this file to .env and fill in your values

# Your domain (required)
DOMAIN=lunchloxs.example.com

# Backend URL (optional — set only for cross-origin deployments)
# When set, frontend and backend are hosted on separate domains.
# Leave blank/commented for same-origin deployments where Traefik
# routes /api and /ws to the backend on the same DOMAIN.
# BACKEND_URL=https://api.lunchloxs.example.com

# PostgreSQL credentials
POSTGRES_USER=lunchloxs
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=lunchloxs
