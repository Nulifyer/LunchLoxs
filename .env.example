# LunchLoxs production environment
# Copy this file to .env and fill in the values you want to override.
# Most settings in docker-compose.prod.yml already have sensible defaults.

POSTGRES_PASSWORD=change-me-to-a-strong-password
DOMAIN=lunchloxs.example.com

# Optional local services on the Ryzen host
# Set to 1 to run the service, 0 to disable it.
ENABLE_LLM=0
ENABLE_SCRAPE=0

# Optional local llama.cpp model override
# Uses llama.cpp -hf shorthand: <org>/<repo>[:quant]
# LLM_MODEL=Qwen/Qwen3-8B-GGUF:Q4_K_M

# Optional app/runtime overrides
# LOG_LEVEL=info
# RATE_LIMIT_PER_SEC=
# RATE_LIMIT_BURST=
# BACKEND_HOST=
# BACKEND_HTTPS=

# Optional LLM/backend overrides
# LLM_ENDPOINT=http://llama:8080
# LLM_API_KEY=
# LLM_PROMPT_DIR=/app/prompts/url-import
# LLM_TIMEOUT=20m
# LLM_DEFAULT_TEMPERATURE=0.7
# LLM_DEFAULT_TOP_P=0.8
# LLM_DEFAULT_MAX_TOKENS=8192
# LLM_PASS0_TEMPERATURE=0.6
# LLM_PASS0_TOP_P=0.95
# LLM_PASS0_MAX_TOKENS=16384
# LLM_PASS1_TEMPERATURE=0.6
# LLM_PASS1_TOP_P=0.95
# LLM_PASS1_MAX_TOKENS=16384
# LLM_PASS2_TEMPERATURE=0.7
# LLM_PASS2_TOP_P=0.8
# LLM_PASS2_MAX_TOKENS=8192
# LLM_PASS3_TEMPERATURE=0.6
# LLM_PASS3_TOP_P=0.95
# LLM_PASS3_MAX_TOKENS=16384

# Optional Browserless override
# BROWSERLESS_ENDPOINT=http://browserless:3000
# BROWSERLESS_TOKEN=
