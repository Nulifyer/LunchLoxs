{
  "name": "recipe-pwa",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/dev-server.ts",
    "build": "bun build src/index.ts --outdir dist --minify && bun build src/workers/service-worker.ts --outdir dist --minify && bun build src/workers/embedding-worker.ts --outdir dist --minify --format esm && bun run scripts/copy-public.ts && bun run scripts/gen-theme-loader.ts",
    "watch": "bun run scripts/watch.ts",
    "preview": "bunx serve dist",
    "test": "bun test",
    "test:unit": "bun test --path-ignore-patterns '**/integration*'",
    "test:integration": "bun test src/lib/__tests__/integration.test.ts"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@huggingface/transformers": "^3.8.1",
    "dompurify": "^3.3.3",
    "hash-wasm": "^4.12.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/dompurify": "^3.2.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.2"
  }
}
