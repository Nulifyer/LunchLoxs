{
  "name": "recipe-pwa",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/dev-server.ts",
    "build": "bun build src/index.ts --outdir dist --minify && bun build src/workers/service-worker.ts --outdir dist --minify && bun run scripts/copy-public.ts && bun run scripts/gen-theme-loader.ts",
    "watch": "bun run scripts/watch.ts",
    "preview": "bunx serve dist"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "dompurify": "^3.3.3",
    "hash-wasm": "^4.12.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "typescript": "^5.7.0"
  }
}
