{
  "name": "todo-frontend",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/dev-server.ts",
    "build": "bun build src/index.ts --outdir dist --minify && bun build src/workers/service-worker.ts --outdir dist --minify && bun run scripts/copy-public.ts",
    "watch": "bun run scripts/watch.ts",
    "preview": "bunx serve dist"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@codemirror/collab": "^6.1.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@picocss/pico": "^2.1.1",
    "codemirror": "^6.0.2",
    "hash-wasm": "^4.12.0",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
